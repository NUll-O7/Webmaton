# Browser
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Target page and form values
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
FORM_NAME_VALUE=John Doe
FORM_DESCRIPTION_VALUE=Automated form fill via Website Automation Agent

# Screenshot output directory (relative to project root)
SCREENSHOT_DIR=screenshots

# Logging (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2
LLM_ENABLED=true
